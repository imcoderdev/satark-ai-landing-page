# =============================================================================
# 🛡️ SATARK AI - Example Environment Configuration
# =============================================================================
# Copy this file to .env and replace the placeholder values with your actual
# API keys and credentials
# =============================================================================

# -----------------------------------------------------------------------------
# 🤖 GOOGLE GEMINI AI CONFIGURATION
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# 📧 EMAIL CONFIGURATION (Optional - for Satark AI email alerts)
# -----------------------------------------------------------------------------
GMAIL_SENDER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_gmail_app_password_here

# -----------------------------------------------------------------------------
# 📝 SETUP INSTRUCTIONS
# -----------------------------------------------------------------------------
# 1. Get Gemini API key: https://makersuite.google.com/app/apikey
# 2. For Gmail: Enable 2FA and generate App Password: https://myaccount.google.com/apppasswords
# 3. Copy this file to .env and replace placeholder values
# 4. Never commit .env file to version control